#!/usr/bin/env bash
set -euo pipefail

# soldebugup - installer for soldebug
#
# Usage:
#   curl -L https://raw.githubusercontent.com/tomw1808/soldebug/main/soldebugup/install | bash
#
# Environment variables:
#   SOLDEBUG_VERSION  - specific version to install (e.g., v0.1.0). Default: latest
#   SOLDEBUG_DIR      - installation directory. Default: ~/.soldebug

REPO="tomw1808/soldebug"
TMP_DIR=""

cleanup() {
    if [ -n "$TMP_DIR" ] && [ -d "$TMP_DIR" ]; then
        rm -rf "$TMP_DIR"
    fi
}
trap cleanup EXIT

main() {
    need_cmd curl
    need_cmd tar
    need_cmd uname

    local version="${SOLDEBUG_VERSION:-latest}"
    local install_dir="${SOLDEBUG_DIR:-$HOME/.soldebug}"
    local bin_dir="$install_dir/bin"

    # Detect platform
    local os arch target
    os=$(uname -s)
    arch=$(uname -m)

    case "$os" in
        Linux)  os="unknown-linux-gnu" ;;
        Darwin) os="apple-darwin" ;;
        *)      err "Unsupported OS: $os" ;;
    esac

    case "$arch" in
        x86_64|amd64)  arch="x86_64" ;;
        arm64|aarch64) arch="aarch64" ;;
        *)             err "Unsupported architecture: $arch" ;;
    esac

    target="${arch}-${os}"

    # Resolve version
    if [ "$version" = "latest" ]; then
        say "Fetching latest release..."
        version=$(curl -fsSL "https://api.github.com/repos/${REPO}/releases/latest" \
            | grep '"tag_name"' | head -1 | cut -d '"' -f 4)
        if [ -z "$version" ]; then
            err "Could not determine latest version. Set SOLDEBUG_VERSION explicitly."
        fi
    fi

    # The tag may include a component prefix (e.g., "soldebug-v0.1.1") or be plain (e.g., "v0.2.0").
    local tag="$version"
    local display_version="${version#soldebug-}"

    say "Installing soldebug ${display_version} (${target})..."

    # Download - try the asset name matching the tag format
    local url="https://github.com/${REPO}/releases/download/${tag}/soldebug-${tag}-${target}.tar.gz"
    TMP_DIR=$(mktemp -d)

    say "Downloading from ${url}..."
    curl -fSL "$url" -o "$TMP_DIR/soldebug.tar.gz" || err "Download failed. Check that version ${version} exists for ${target}."

    # Extract
    tar xzf "$TMP_DIR/soldebug.tar.gz" -C "$TMP_DIR"

    # Install
    mkdir -p "$bin_dir"
    mv "$TMP_DIR/soldebug" "$bin_dir/soldebug"
    chmod +x "$bin_dir/soldebug"

    say ""
    say "soldebug ${display_version} installed to ${bin_dir}/soldebug"
    say ""

    # Check PATH
    case ":$PATH:" in
        *":$bin_dir:"*) ;;
        *)
            say "Add soldebug to your PATH by adding this to your shell profile:"
            say ""
            say "  export PATH=\"${bin_dir}:\$PATH\""
            say ""
            # Try to detect shell and suggest the right file
            local shell_profile=""
            case "${SHELL:-}" in
                */zsh)  shell_profile="~/.zshenv" ;;
                */bash) shell_profile="~/.bashrc" ;;
                */fish) shell_profile="~/.config/fish/config.fish" ;;
            esac
            if [ -n "$shell_profile" ]; then
                say "For your shell, add it to ${shell_profile}:"
                say ""
                say "  echo 'export PATH=\"${bin_dir}:\$PATH\"' >> ${shell_profile}"
                say ""
            fi
            ;;
    esac

    say "Run 'soldebug --help' to get started."
}

say() {
    printf "soldebugup: %s\n" "$1"
}

err() {
    say "error: $1" >&2
    exit 1
}

need_cmd() {
    if ! command -v "$1" &>/dev/null; then
        err "need '$1' (command not found)"
    fi
}

main "$@"
